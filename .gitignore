gitignore
深色版本
# 忽略 node_modules 文件夹
node_modules/
 
# 其他常见需要忽略的文件（可选）
npm-debug.log
yarn-error.log
yarn-debug.log
.pnpm-debug.log
 
# 环境变量文件（敏感信息！）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
 
# IDE 和编辑器生成的文件
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.log
 
# 构建输出目录（如果你有构建过程）
dist/
build/
out/
.next/
nuxt/