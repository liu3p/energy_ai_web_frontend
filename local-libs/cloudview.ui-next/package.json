{
  "name": "cloudview.ui-next",
  "version": "2.9.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "sass": {
    "includePaths": [
      "node_modules"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/lib/index.js",
      "import": "./dist/es/index.mjs"
    },
    "./utils": {
      "require": "./dist/lib/utils/index.js",
      "import": "./dist/es/utils/index.mjs"
    },
    "./locale/lang/*": {
      "require": "./dist/lib/locale/lang/*",
      "import": "./dist/es/locale/lang/*"
    },
    "./theme-chalk/*": "./dist/theme-chalk/*",
    "./es": "./dist/es/index.mjs",
    "./es/*": "./dist/es/*.mjs",
    "./es/*.mjs": "./dist/es/*.mjs",
    "./lib": "./dist/lib/index.js",
    "./lib/*": "./dist/lib/*.js",
    "./lib/*.js": "./dist/lib/*.js"
  },
  "sideEffects": [
    "dist/*",
    "dist/es/*/style/*"
  ],
  "main": "dist/lib/index.js",
  "module": "dist/es/index.mjs",
  "vetur": {
    "tags": "dist/tags.json",
    "attributes": "dist/attributes.json"
  },
  "web-types": "dist/web-types.json",
