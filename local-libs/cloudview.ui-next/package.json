  "scripts": {
    "build": "gulp --require sucrase/register/ts -f ./build/gulpfile.ts",
    "clean": "rimraf dist",
    "dev": "vite dev",
    "gen": "bash ./build/gc.sh",
    "lint": "eslint --fix ./packages --ext .vue,.js,.ts",
    "lint:style": "stylelint ./packages/**/*.{css,scss,vue} --fix",
    "dev-docs": "vitepress dev docs",
    "build-docs": "node --max_old_space_size=4096 ./node_modules/vitepress/bin/vitepress.js build docs",
    "preview-docs": "vitepress preview docs"
  }
